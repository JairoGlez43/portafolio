# Copy to .env.local for local development.
# In Vercel, set these as Environment Variables on the project settings.

# Required for sending contact form emails in production.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: custom verified sender once you own a domain in Resend.
# Defaults to "Portafolio <onboarding@resend.dev>" if unset.
CONTACT_FROM_EMAIL=

# Site URL used by sitemap.ts, robots.ts and OpenGraph defaults.
NEXT_PUBLIC_SITE_URL=https://jairogonzalez.vercel.app
